---
const stats = [
    { number: "25+", label: "Jaren ervaring" },
    { number: "500+", label: "Tevreden klanten" },
    { number: "10.000+", label: "Hectare in beheer" },
    { number: "100%", label: "Betrouwbaar" }
];
---
<section id="over-ons" class="py-24 bg-gray-50">
    <div class="container">
        <div class="grid md:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h2 class="text-4xl font-bold">Ervaren rentmeesters met passie voor het vak</h2>
                <p class="text-gray-600 text-lg">
                    Als modern rentmeesterkantoor combineren we traditionele waarden met innovatieve oplossingen. 
                    Onze expertise ligt in het duurzaam beheren en optimaliseren van landelijk vastgoed.
                </p>
                <div class="grid grid-cols-2 gap-8 mt-12">
                    {stats.map(stat => (
                        <div>
                            <div class="text-4xl font-bold text-green-700">{stat.number}</div>
                            <div class="text-gray-600">{stat.label}</div>
                        </div>
                    ))}
                </div>
            </div>
            <div class="relative">
                <img 
                    src="/images/about-image.jpg" 
                    alt="Landelijk gebied" 
                    class="rounded-2xl shadow-xl"
                />
                <div class="absolute -bottom-6 -left-6 bg-white p-8 rounded-xl shadow-lg">
                    <p class="text-lg font-semibold text-green-700">
                        "Professioneel, betrouwbaar en altijd bereikbaar voor onze klanten"
                    </p>
                </div>
            </div>
        </div>
    </div>
</section> 